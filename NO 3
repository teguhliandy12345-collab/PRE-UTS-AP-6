#include <iostream>
using namespace std;

int main() {
    int jumlahBaris;

    cout << "INPUT  : ";
    cin >> jumlahBaris;

    cout << "OUTPUT : " << endl;

    for (int i = 0; i < jumlahBaris; i++) {
        int angka = 1;
        
        if (i == 0) cout << "         ";
        else cout << "         "; 

        for (int j = 0; j <= i; j++) {
            cout << angka << "  ";
    
            angka = angka * (i - j) / (j + 1);
        }
        cout << endl;
    }

    return 0;
}
